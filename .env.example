# Gemini AI configuration
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# OpenRouter fallback model API (optional)
OPENROUTER_API_KEY=

# Plivo PSTN configuration
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
PUBLIC_URL=

# WhatsApp integration (Evolution/Evo-Go)
EVOLUTION_API_URL=https://evo-go.tech.onegroup.co.in
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=main-whatsapp

# PostgreSQL/Supabase connection (required)
DATABASE_URL=

# Dashboard and classifier configuration
CLASSIFIER_DASHBOARD_URL=

# Server and data storage
PORT=8100
# DATA_DIR is the PARENT directory. Calls are stored under $DATA_DIR/calls, while
# brochures.json, prompt-override.txt, model-override.txt sit at $DATA_DIR/.
# Leave unset for Docker (resolves to /data parent + /data/calls for call files).
# On host: DATA_DIR=/home/office/gemini-live-app-native/data
DATA_DIR=
